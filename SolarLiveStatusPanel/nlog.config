<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.nlog-project.org/schemas/NLog.xsd NLog.xsd"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Off"
      internalLogFile="c:\temp\nlog-internal.log">

	<targets>
		<target 
				xsi:type="Console"
				name="consoleTarget"
				layout="SolarLiveStatusPanel ${uppercase:${level}} ${message}" />

		<target 
				xsi:type="File"
				name="fileTarget"
				fileName="logs/solar.log"
				archiveFileName="logs/solar.log"
				archiveSuffixFormat="_{1:yyyyMMdd}"
				archiveEvery="Day"
				archiveNumbering="Rolling"
				maxArchiveFiles="7"
				keepFileOpen="false"
				layout="${date:format=dd.MM.yyyy HH\\:mm\\:ss,fff} | ${padding:padding=5,fixedlength=true:${level:uppercase=true}} | ${message} | ">
		</target>
	</targets>

	<rules>
		<logger name="*" writeTo="fileTarget" />
		<logger name="*" writeTo="consoleTarget" />
	</rules>
</nlog>